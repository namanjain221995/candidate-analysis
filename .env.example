# ── AWS ──────────────────────────────────────────────
AWS_REGION=us-east-1
BUCKET=candidate-deliverables
TRANSCRIPT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<ACCOUNT_ID>/transcript-jobs

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_WHISPER_MODEL=whisper-1
LANGUAGE=en

# ── Workers / tuning ─────────────────────────────────
WORKER_THREADS=4
SQS_WAIT_SECONDS=20
SQS_VISIBILITY_TIMEOUT=1800
CHUNK_SECONDS=540
OVERLAP_SECONDS=2
OPENAI_AUDIO_BITRATE=64k
TRANSCRIPT_SUFFIX=_transcripts.txt
FORCE_RETRANSCRIBE=false
OPENAI_TRANSCRIBE_PROMPT=Transcribe exactly what is spoken. Do not correct grammar. Do not fix technical terms. Preserve filler words, repetitions, false starts, and wrong words.

# ── LLM scoring stage ────────────────────────────────
LLM_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<ACCOUNT_ID>/llm-jobs
OPENAI_LLM_MODEL=gpt-4o
LLM_WORKER_THREADS=4
# Pass/Fail tags appended to every file in a deliverable folder after analysis
LLM_PASS_MARKER=(Pass)
LLM_FAIL_MARKER=(Fail)

# ── Salesforce callout (JWT bearer; creds in AWS Secrets Manager) ──#
SF_ENABLED=false
SF_SECRET_NAME=sf/jwt/credentials
SF_APEX_PATH=/services/apexrest/deliverableResult
SF_AUDIENCE=https://login.salesforce.com
SF_TIMEOUT=30