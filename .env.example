
# ── AWS ──────────────────────────────────────────────
AWS_REGION=us-east-1
BUCKET=candidate-deliverables
TRANSCRIPT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<ACCOUNT_ID>/transcript-jobs

# ── OpenAI ───────────────────────────────────────────
# NOTE: OpenAI/Whisper is NO LONGER used for transcription (Whisper is retired).
# The OpenAI key is still REQUIRED by the LLM scoring stage (gpt-5.5) and the
# code-evaluation stage — keep the account funded. OPENAI_WHISPER_MODEL is now
# unused (kept only for the dormant rollback path).
OPENAI_API_KEY=sk-...
OPENAI_WHISPER_MODEL=whisper-1
LANGUAGE=en

# ── AssemblyAI — PRODUCTION transcription engine ─────
# AssemblyAI is now the ONLY transcriber. ASSEMBLYAI_API_KEY is REQUIRED: if it's
# blank the transcript service refuses to start (nothing would get transcribed).
# Its transcripts/results are UNTAGGED (clean names) and pushed to Salesforce.
ASSEMBLYAI_API_KEY=
# Speech model(s), comma-separated in priority order. MUST be a currently-supported
# model: a deprecated one (e.g. universal-3-pro, retired by AssemblyAI in 2026) makes
# the API 400-reject the request and NOTHING gets transcribed. universal-2 is the
# safe default. Adopt a newer model (e.g. universal-3-5-pro) only after confirming
# the exact id, keeping universal-2 as the trailing fallback.
ASSEMBLYAI_SPEECH_MODELS=universal-2
ASSEMBLYAI_DISFLUENCIES=true
ASSEMBLYAI_POLL_SECONDS=3
ASSEMBLYAI_POLL_MAX_ATTEMPTS=600
# NOTE: TRANSCRIPTION_ENGINES is IGNORED now — the code always runs AssemblyAI
# only (Whisper is retired and can't be re-enabled via env). Left here for
# documentation; changing it has no effect.
TRANSCRIPTION_ENGINES=A

# ── Workers / tuning ─────────────────────────────────
WORKER_THREADS=4
SQS_WAIT_SECONDS=20
SQS_VISIBILITY_TIMEOUT=1800
CHUNK_SECONDS=180
OVERLAP_SECONDS=2
OPENAI_AUDIO_BITRATE=64k
TRANSCRIPT_SUFFIX=_transcripts.txt
FORCE_RETRANSCRIBE=false

# ── LLM scoring stage ────────────────────────────────
LLM_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<ACCOUNT_ID>/llm-jobs
OPENAI_LLM_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
LLM_WORKER_THREADS=4
# Pass/Fail tags appended to every file in a deliverable folder after analysis
LLM_PASS_MARKER=(Pass)
LLM_FAIL_MARKER=(Fail)
# ── Deterministic scoring (same input → same verdict) ──
# OPENAI_SEED   : fixed request seed for best-effort determinism (auto-dropped if a
#                 reasoning model rejects it). Change it to reshuffle scoring.
# LLM_CACHE_*   : content-hash result cache in S3 — GUARANTEES an identical verdict
#                 when the exact same submission is re-scored. Set enabled=false to
#                 always re-score. Cache objects: <prefix><sha256>.json (bucket root).
OPENAI_SEED=7
LLM_CACHE_ENABLED=true
LLM_CACHE_PREFIX=_llm_cache/

# ── Code-evaluation stage (Advanced Training .ipynb/.py) ──
# New, additive worker (code_worker.py) that consumes the notebook-jobs queue the
# Router Lambda feeds. Candidate notebooks are NOT executed — their saved outputs
# and charts are read and sent to OpenAI. Reuses OPENAI_API_KEY and the SF_* vars.
# Main queue only. The DLQ (notebook-jobs-dlq) is attached via the queue's redrive
# policy in SQS and is never referenced by code or env.
NOTEBOOK_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/985100584614/notebook-jobs
CODE_WORKER_THREADS=4
CODE_SQS_VISIBILITY_TIMEOUT=1800
# Own model knob (falls back to OPENAI_LLM_MODEL, then gpt-5.5). Must be vision-capable.
OPENAI_CODE_MODEL=gpt-5.5
OPENAI_CODE_REASONING_EFFORT=medium
# Deterministic code scoring — own knobs; fall back to OPENAI_SEED / LLM_CACHE_ENABLED.
# The cache guarantees a re-scored identical .ipynb/.py gets the same verdict.
OPENAI_CODE_SEED=7
CODE_LLM_CACHE_ENABLED=true
# Size/cost caps for big notebooks
CODE_MAX_OUTPUT_CHARS_PER_CELL=2000
CODE_MAX_TOTAL_CHARS=120000
CODE_MAX_IMAGES=10
CODE_MAX_CODE_CHARS=100000
# Duplicate-event protection (S3 marker per processed upload)
CODE_DEDUP_ENABLED=true
# Salesforce for CODE results — ON by default. CODE_SF_ENABLED overrides (unset =
# inherit SF_ENABLED, else default true). Set to false to keep code results out of
# Salesforce without touching the video pipeline. REQUIRES SF_CLIENT_ID +
# SF_CLIENT_SECRET below (and SF_LOGIN_URL / SF_APEX_PATH) for the push to work.
CODE_SF_ENABLED=true

# ── Salesforce callout (OAuth client_credentials → Bearer POST) ──#
SF_ENABLED=false
SF_LOGIN_URL=https://techsara--dev9.sandbox.my.salesforce.com
SF_APEX_PATH=/services/apexrest/v1/deliverable-result/
SF_CLIENT_ID=your-connected-app-consumer-key
SF_CLIENT_SECRET=your-connected-app-secret
SF_TIMEOUT=30