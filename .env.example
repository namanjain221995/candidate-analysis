
# ── AWS ──────────────────────────────────────────────
AWS_REGION=us-east-1
BUCKET=candidate-deliverables
TRANSCRIPT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<ACCOUNT_ID>/transcript-jobs

# ── OpenAI (Whisper engine = W) ──────────────────────
OPENAI_API_KEY=sk-...
OPENAI_WHISPER_MODEL=whisper-1
LANGUAGE=en

# ── AssemblyAI (engine = A — parallel A/B engine, S3-only) ──
# Leave ASSEMBLYAI_API_KEY blank to run Whisper only (the (A) path is skipped
# with a warning; production is unaffected). Model + disfluencies are PINNED so
# provider changes can't silently skew the comparison.
ASSEMBLYAI_API_KEY=
# Priority-ordered model list — AssemblyAI auto-routes to the first supported
# model and falls back to the next. Default = AssemblyAI's own default.
ASSEMBLYAI_SPEECH_MODELS=universal-3-pro,universal-2
ASSEMBLYAI_DISFLUENCIES=true
ASSEMBLYAI_POLL_SECONDS=3
ASSEMBLYAI_POLL_MAX_ATTEMPTS=600
# Engines run per video (comma-separated). Whisper always runs first. Set to "W"
# to disable AssemblyAI entirely.
TRANSCRIPTION_ENGINES=W,A

# ── Workers / tuning ─────────────────────────────────
WORKER_THREADS=4
SQS_WAIT_SECONDS=20
SQS_VISIBILITY_TIMEOUT=1800
CHUNK_SECONDS=180
OVERLAP_SECONDS=2
OPENAI_AUDIO_BITRATE=64k
TRANSCRIPT_SUFFIX=_transcripts.txt
FORCE_RETRANSCRIBE=false

# ── LLM scoring stage ────────────────────────────────
LLM_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<ACCOUNT_ID>/llm-jobs
OPENAI_LLM_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=low
LLM_WORKER_THREADS=4
# Pass/Fail tags appended to every file in a deliverable folder after analysis
LLM_PASS_MARKER=(Pass)
LLM_FAIL_MARKER=(Fail)

# ── Salesforce callout (OAuth client_credentials → Bearer POST) ──#
SF_ENABLED=false
SF_LOGIN_URL=https://techsara--dev9.sandbox.my.salesforce.com
SF_APEX_PATH=/services/apexrest/v1/deliverable-result/
SF_CLIENT_ID=your-connected-app-consumer-key
SF_CLIENT_SECRET=your-connected-app-secret
SF_TIMEOUT=30